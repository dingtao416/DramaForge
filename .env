# ============================================
# DramaForge - AI Short Drama Engine
# Environment Configuration
# All AI services unified through laozhang.ai
# ============================================

# ----- Server -----
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=dramaforge-dev-secret-key-2026

# ----- Database -----
DATABASE_URL=sqlite:///./storage/dramaforge.db

# ----- Redis (for Celery task queue) -----
REDIS_URL=redis://localhost:6379/0

# =============================================
# Unified API Gateway - laozhang.ai
# =============================================
LAOZHANG_API_KEY=sk-uyLZ1oqJvLd9iEyeD85cC947D08449Bc9a304a7d4a42Bc42
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1

# ----- LLM -----
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ----- Image Generation -----
IMAGE_MODEL=sora-image
IMAGE_SIZE=1024x1792

# ----- TTS -----
TTS_MODEL=tts-1-hd
TTS_DEFAULT_VOICE=nova
TTS_SPEED=1.0

# ----- Video Generation (Sora 2) -----
VIDEO_MODEL=veo-3.1-fast
VIDEO_SIZE=1280x720
VIDEO_SECONDS=10
VIDEO_USE_ASYNC=true
VIDEO_POLL_INTERVAL=5
VIDEO_TIMEOUT=600

# ----- FFmpeg -----
FFMPEG_PATH=ffmpeg

# ----- Storage -----
STORAGE_DIR=./storage
