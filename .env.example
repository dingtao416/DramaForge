# ============================================
# DramaForge - AI Short Drama Engine
# Environment Configuration
#
# All AI services are unified through laozhang.ai
# Docs: https://docs.laozhang.ai/
# Console: https://api.laozhang.ai/
# ============================================

# ----- Server -----
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=your-secret-key-change-me

# ----- Database -----
DATABASE_URL=sqlite:///./storage/dramaforge.db

# ----- Redis (for Celery task queue) -----
REDIS_URL=redis://localhost:6379/0

# =============================================
# Unified API Gateway - laozhang.ai
# Register at https://api.laozhang.ai/ to get your API key
# One key, all AI models (200+ models supported)
# =============================================
LAOZHANG_API_KEY=sk-your-laozhang-api-key
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1

# ----- LLM (Text Generation) -----
# Available: gpt-4.1, gpt-4o, o3, o4-mini,
#            claude-sonnet-4-20250514, gemini-2.5-pro,
#            deepseek-v3, deepseek-r1, qwen-max, etc.
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ----- Image Generation -----
# Models & pricing (per image):
#   sora-image       $0.01  (best value, recommended for batch)
#   flux-pro         $0.035 (flexible ratio 3:7~7:3)
#   flux-max         $0.07  (highest quality)
#   nano-banana      $0.025 (base64 output)
#   nano-banana-pro  $0.05  (4K HD)
#   gpt-image-1      by token
IMAGE_MODEL=sora-image
IMAGE_SIZE=1024x1792

# ----- TTS (Text-to-Speech) -----
# Models: tts-1 (standard, fast) | tts-1-hd (HD, more natural)
# Voices: alloy (neutral), echo (male), fable (british),
#         onyx (deep male), nova (female), shimmer (soft female)
TTS_MODEL=tts-1-hd
TTS_DEFAULT_VOICE=nova
TTS_SPEED=1.0

# ----- Video Generation (Sora 2) -----
# Async models (recommended): sora-2 ($0.15/video), sora-2-pro ($0.8/video, 1080P)
# Size: 1280x720 (landscape) | 720x1280 (portrait)
# Seconds: 10 or 15
VIDEO_MODEL=sora-2
VIDEO_SIZE=1280x720
VIDEO_SECONDS=10
VIDEO_USE_ASYNC=true
VIDEO_POLL_INTERVAL=5
VIDEO_TIMEOUT=600

# ----- FFmpeg -----
FFMPEG_PATH=ffmpeg

# ----- Storage -----
STORAGE_DIR=./storage
